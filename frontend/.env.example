GENERATE_SOURCEMAP=false

# Dev server port (Create React App)
PORT=3030

# API (no trailing slash on URL)
REACT_APP_SERVER_URL=http://127.0.0.1:5000
REACT_APP_WS_SERVER_URL=ws://127.0.0.1:5000

# Payments (publishable / client IDs only)
REACT_APP_STRIPE_PUBLIC_KEY=
REACT_APP_PAYPAL_CLIENT_ID=

# Optional
REACT_APP_MAPBOX_API=
REACT_APP_MODE=stock
